# Variáveis de Ambiente - Angelical Decor Messenger Bot

# Porta de execução
PORT=3000

# Token de verificação do Facebook Webhook
VERIFY_TOKEN=angelical_bot_token

# Access Token da Página Facebook
# Como obter: https://developers.facebook.com/docs/messenger-platform/getting-started
PAGE_ACCESS_TOKEN=seu_page_access_token_aqui

# Ambiente
NODE_ENV=development
